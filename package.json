{
  "name": "lcg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-powered sales operations toolkit for LCG",
  "bin": {
    "lcg": "./bin/lcg.js"
  },
  "scripts": {
    "bootstrap": "node scripts/bootstrap.js",
    "bootstrap:check": "node scripts/bootstrap.js --check",
    "setup": "node scripts/init.js",
    "check": "node scripts/init.js --check",
    "vault:init": "node scripts/bootstrap-vault.js",
    "vault:hygiene": "node scripts/run.js vault-hygiene",
    "outlook:rules": "node scripts/setup-outlook-rules.js",
    "task": "node scripts/run.js",
    "task:list": "node scripts/run.js list",
    "task:morning": "node scripts/run.js morning-triage",
    "task:milestone": "node scripts/run.js milestone-review",
    "task:learning": "node scripts/run.js learning-review",
    "task:hygiene": "node scripts/run.js vault-hygiene",
    "task:portfolio": "node scripts/run.js portfolio-review",
    "task:meeting-brief": "node scripts/run.js meeting-brief",
    "task:meeting-followup": "node scripts/run.js meeting-followup",
    "task:update-request": "node scripts/run.js update-request",
    "task:morning-corrections": "node scripts/run.js morning-corrections",
    "task:meeting-prep-trigger": "node scripts/run.js meeting-prep-trigger",
    "morning:prep": "node scripts/run.js morning-triage",
    "morning:corrections": "node scripts/run.js morning-corrections",
    "morning:schedule": "node scripts/install-scheduler.js --task morning-triage --time 07:00",
    "meeting:prep:trigger": "node scripts/run.js meeting-prep-trigger",
    "meeting:followup": "node scripts/run.js meeting-followup",
    "update-request:run": "node scripts/run.js update-request",
    "learning:review": "node scripts/run.js learning-review",
    "setup": "node scripts/init.js",
    "docs:install": "pip install -r site/requirements.txt",
    "docs:serve": "mkdocs serve -f site/mkdocs.yml",
    "docs:build": "mkdocs build -f site/mkdocs.yml",
    "docs:deploy": "mkdocs gh-deploy --force -f site/mkdocs.yml",
    "subtree:sync": "bash scripts/subtree-sync.sh",
    "subtree:sync:dry": "bash scripts/subtree-sync.sh --dry-run",
    "subtree:sync:all": "bash scripts/subtree-sync.sh --all",
    "eval": "vitest run --config vitest.config.ts",
    "eval:watch": "vitest --config vitest.config.ts",
    "eval:live": "vitest run --config evals/vitest.live.config.ts",
    "eval:live:watch": "vitest --config evals/vitest.live.config.ts",
    "eval:all": "vitest run --config vitest.config.ts && vitest run --config evals/vitest.live.config.ts",
    "eval:matrix": "node scripts/eval-model-matrix.js",
    "eval:matrix:all": "node scripts/eval-model-matrix.js --lane all",
    "eval:matrix:anthropic": "node scripts/eval-model-matrix.js --lane non-anthropic --include-anthropic",
    "eval:matrix:dry": "node scripts/eval-model-matrix.js --dry-run",
    "eval:baseline": "vitest run --config vitest.config.ts && node scripts/eval-persist.js --baseline --update",
    "eval:diff": "node scripts/eval-persist.js --diff",
    "eval:history": "node scripts/eval-persist.js --history",
    "eval:trace": "npx tsx evals/traces/trace-harness.ts",
    "fixtures:capture": "node scripts/capture-fixtures.js",
    "fixtures:capture:dry": "node scripts/capture-fixtures.js --dry-run",
    "fixtures:capture:redact": "node scripts/capture-fixtures.js --redact"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "mermaid": "^11.13.0",
    "openai": "^6.29.0",
    "pptxgenjs": "^4.0.1",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "docx": "^9.6.1",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  }
}
