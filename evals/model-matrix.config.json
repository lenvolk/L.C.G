{
  "description": "Lightweight model matrix for L.C.G agent/prompt evals",
  "defaults": {
    "iterations": 1,
    "timeoutSec": 480,
    "includeAnthropic": false
  },
  "modelPools": {
    "nonAnthropic": [
      "GPT-5.4 mini (copilot)",
      "GPT-5.2 (copilot)",
      "GPT-5.3-Codex (copilot)",
      "Gemini 3 Flash (Preview)"
    ],
    "anthropic": [
      "Claude Haiku 4.5 (copilot)",
      "Claude Sonnet 4.6 (copilot)",
      "Claude Opus 4.6 (copilot)"
    ]
  },
  "scenarios": [
    {
      "id": "chief-morning-triage",
      "agent": "Chief of Staff",
      "type": "command",
      "command": "bash scripts/morning-prep.sh",
      "requiresEnv": ["OBSIDIAN_VAULT_PATH"],
      "timeoutSec": 480
    },
    {
      "id": "chief-learning-review",
      "agent": "Chief of Staff",
      "type": "command",
      "command": "bash scripts/learning-review.sh",
      "requiresEnv": ["OBSIDIAN_VAULT_PATH"],
      "timeoutSec": 420
    },
    {
      "id": "chief-meeting-followup",
      "agent": "Chief of Staff",
      "type": "command",
      "command": "bash scripts/meeting-followup.sh",
      "requiresEnv": ["OBSIDIAN_VAULT_PATH"],
      "env": {
        "MEETING_NAME": "Model Eval Sync",
        "MEETING_FILE_SLUG": "model-eval-sync",
        "CUSTOMER_OR_TOPIC": "Contoso"
      },
      "timeoutSec": 420
    },
    {
      "id": "pbi-cxobserve-account-review",
      "agent": "pbi-analyst",
      "type": "prompt",
      "promptFile": ".github/prompts/pbi-cxobserve-account-review.prompt.md",
      "timeoutSec": 420
    },
    {
      "id": "pbi-pipeline-excellence",
      "agent": "pbi-analyst",
      "type": "prompt",
      "promptFile": ".github/prompts/pbi-pipeline-excellence-uncommitted-to-commit.prompt.md",
      "timeoutSec": 420
    },
    {
      "id": "pbi-se-productivity-review",
      "agent": "pbi-analyst",
      "type": "prompt",
      "promptFile": ".github/prompts/pbi-se-productivity-review.prompt.md",
      "timeoutSec": 420
    }
  ]
}
